<nav class="navbar <%= user ? 'navbar-private' : 'navbar-public' %>">
  <div class="nav-container">
    <% if (!user) { %>
      <a href="/" class="nav-logo">
        <svg class="logo-icon-svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="8" stroke-linecap="square" stroke-linejoin="miter">
          <polyline points="30,40 10,55 30,70" />
          <polyline points="40,80 55,40 70,55 90,25" />
          <polygon points="75,20 95,20 95,40" fill="currentColor" stroke="none" />
          <polyline points="60,55 80,70 60,85" />
        </svg> CodeTrack
      </a>
      <ul class="nav-links">
        <li><a href="/" class="btn-text">Home</a></li>
        <li><a href="/auth/login" class="btn-text">Log In</a></li>
        <li><a href="/auth/signup" class="btn-primary">Sign Up</a></li>
      </ul>
