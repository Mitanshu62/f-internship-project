<%- include('../partials/header') %>

<section class="hero">
  <div class="hero-content">
    <h1 class="hero-title">Track. <span class="gradient-text">Improve.</span> Stay Consistent.</h1>
    <p class="hero-subtitle">CodeTrack helps you build a daily coding habit, analyze your progress, and prepare for your next big tech interview.</p>
    <div class="hero-cta">
      <a href="/auth/signup" class="btn-primary btn-lg">Get Started</a>
      <a href="#features" class="btn-secondary btn-lg">Learn More</a>
    </div>
  </div>
  <div class="hero-visual">
    <div class="glass-card mockup-card">
      <div class="mockup-header">
        <span class="dot dot-red"></span>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
      </div>
      <div class="mockup-body">
        <div class="mockup-line w-75"></div>
        <div class="mockup-line w-50"></div>
        <div class="mockup-line w-85"></div>
        <div class="mockup-line w-40 mt-3"></div>
      </div>
    </div>
  </div>
</section>

<section id="features" class="features">
  <h2 class="section-title">Why CodeTrack?</h2>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">🔥</div>
      <h3>Maintain Streaks</h3>
      <p>Keep your momentum going. Our streak tracker motivates you to code every single day.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📊</div>
      <h3>Rich Statistics</h3>
      <p>Visualize your progress with beautiful charts and distribution stats across topics and platforms.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🧠</div>
      <h3>Smart Notes</h3>
      <p>Store your thoughts, intuition, and time complexities for quick revision before interviews.</p>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>
