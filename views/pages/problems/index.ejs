<%- include('../../partials/header') %>

<div class="dashboard-header">
  <div>
    <h1 class="page-title">All Problems</h1>
    <p class="text-muted">Track and filter your problem solving history</p>
  </div>
  <a href="/problems/add" class="btn-primary">Add Problem</a>
</div>

<div class="filters-container glass-card">
  <form action="/problems" method="GET" class="filters-form">
    <!-- Keep search query if it exists -->
    <% if (query.search) { %>
      <input type="hidden" name="search" value="<%= query.search %>">
    <% } %>
    
    <div class="filter-group">
      <label>Platform</label>
      <select name="platform" class="form-control">
        <option value="">All</option>
        <option value="LeetCode" <%= query.platform === 'LeetCode' ? 'selected' : '' %>>LeetCode</option>
        <option value="GeeksforGeeks" <%= query.platform === 'GeeksforGeeks' ? 'selected' : '' %>>GeeksforGeeks</option>
        <option value="Codeforces" <%= query.platform === 'Codeforces' ? 'selected' : '' %>>Codeforces</option>
        <option value="CodeChef" <%= query.platform === 'CodeChef' ? 'selected' : '' %>>CodeChef</option>
        <option value="HackerRank" <%= query.platform === 'HackerRank' ? 'selected' : '' %>>HackerRank</option>
        <option value="AtCoder" <%= query.platform === 'AtCoder' ? 'selected' : '' %>>AtCoder</option>
        <option value="Other" <%= query.platform === 'Other' ? 'selected' : '' %>>Other</option>
      </select>
    </div>
    
    <div class="filter-group">
      <label>Difficulty</label>
      <select name="difficulty" class="form-control">
        <option value="">All</option>
        <option value="Easy" <%= query.difficulty === 'Easy' ? 'selected' : '' %>>Easy</option>
        <option value="Medium" <%= query.difficulty === 'Medium' ? 'selected' : '' %>>Medium</option>
        <option value="Hard" <%= query.difficulty === 'Hard' ? 'selected' : '' %>>Hard</option>
      </select>
    </div>
    
    <div class="filter-group">
      <label>Status</label>
      <select name="status" class="form-control">
        <option value="">All</option>
        <option value="Solved" <%= query.status === 'Solved' ? 'selected' : '' %>>Solved</option>
        <option value="Attempted" <%= query.status === 'Attempted' ? 'selected' : '' %>>Attempted</option>
        <option value="Revisit" <%= query.status === 'Revisit' ? 'selected' : '' %>>Revisit</option>
      </select>
    </div>

    <div class="filter-group">
      <label>Sort By</label>
      <select name="sort" class="form-control">
        <option value="newest" <%= query.sort === 'newest' ? 'selected' : '' %>>Newest First</option>
        <option value="oldest" <%= query.sort === 'oldest' ? 'selected' : '' %>>Oldest First</option>
        <option value="easy_first" <%= query.sort === 'easy_first' ? 'selected' : '' %>>Easy First</option>
        <option value="hard_first" <%= query.sort === 'hard_first' ? 'selected' : '' %>>Hard First</option>
        <option value="time_taken" <%= query.sort === 'time_taken' ? 'selected' : '' %>>Time Taken</option>
      </select>
    </div>
    
    <div class="filter-actions">
      <button type="submit" class="btn-primary">Apply Filters</button>
      <a href="/problems" class="btn-secondary">Clear</a>
    </div>
  </form>
</div>

<div class="problem-list">
  <% if (problems.length > 0) { %>
    <% problems.forEach(problem => { %>
      <div class="problem-card glass-card">
        <div class="problem-main">
          <span class="status-icon <%= problem.status === 'Solved' ? 'status-solved' : (problem.status === 'Attempted' ? 'status-attempted' : 'status-revisit') %>">
            <% if (problem.status === 'Solved') { %> ✓ <% } else if (problem.status === 'Attempted') { %> ! <% } else { %> ↻ <% } %>
          </span>
          <div class="problem-title-box">
            <h4 class="problem-title"><%= problem.title %></h4>
            <span class="problem-platform"><%= problem.platform %></span>
          </div>
        </div>
        <div class="problem-meta">
          <span class="badge badge-<%= problem.difficulty.toLowerCase() %>"><%= problem.difficulty %></span>
          <span class="badge badge-topic"><%= problem.topic %></span>
          <span class="problem-date"><%= new Date(problem.dateSolved).toLocaleDateString() %></span>
        </div>
        <div class="problem-actions">
          <a href="/problems/<%= problem._id %>" class="btn-sm btn-text">View</a>
          <a href="/problems/<%= problem._id %>/edit" class="btn-sm btn-secondary">Edit</a>
          <form action="/problems/<%= problem._id %>?_method=DELETE" method="POST" class="inline-form" onsubmit="return confirm('Are you sure you want to delete this problem?');">
            <button type="submit" class="btn-sm btn-danger">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <div class="empty-state glass-card mt-3">
      <div class="empty-icon">🔍</div>
      <h3>No problems found</h3>
      <p>Try adjusting your filters or search query.</p>
    </div>
  <% } %>
</div>

<%- include('../../partials/footer') %>
