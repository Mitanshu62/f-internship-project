# ==================================================
# CodeTrack Environment Variables Template
# ==================================================
# Instructions:
# 1. Copy this file and rename it to .env
# 2. Replace the placeholder values with your actual configuration
# 3. DO NOT commit your actual .env file to version control

# --------------------------------------------------
# Server Configuration
# --------------------------------------------------
# The environment the app is running in (development, test, or production)
NODE_ENV=development

# The port the application will listen on (defaults to 3000)
PORT=3000

# --------------------------------------------------
# Database Configuration (MongoDB Atlas)
# --------------------------------------------------
# Your standard MongoDB Atlas connection string.
# Example: mongodb+srv://<username>:<password>@cluster.mongodb.net/codetrack?retryWrites=true&w=majority
MONGODB_URI=

# --------------------------------------------------
# Session & Authentication
# --------------------------------------------------
# A strong, random string used to encrypt session cookies.
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
